{
  "expo": {
    "name": "giant-js",
    "slug": "github-giant-js",
    "owner": "nitishkc7075s-team",
    "version": "1.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "main": "expo-router/entry",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.nitishkc7075.giantjs"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "eas": {
        "projectId": "8a8337ba-43a2-4a59-b9cd-2fa0b744dcfc"
      }
    }
  }
}
